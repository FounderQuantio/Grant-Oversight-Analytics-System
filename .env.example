# FraudGuard GFDS v4 — Environment Variables
# Copy this file to .env.local and fill in values

# Application
VITE_APP_NAME="FraudGuard Grant Intelligence Platform"
VITE_APP_VERSION="4.1.0"
VITE_APP_ENV="development"

# API (for future backend integration)
# VITE_API_BASE_URL=https://api.yourserver.com
# VITE_API_KEY=your_api_key_here

# Feature Flags
VITE_ENABLE_ML_ENGINE=true
VITE_ENABLE_GRAPH_ENGINE=true
VITE_ENABLE_ROI_CALCULATOR=true
VITE_ENABLE_REPORT_EXPORT=true

# Analytics (optional)
# VITE_ANALYTICS_ID=your_analytics_id
